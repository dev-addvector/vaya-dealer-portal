generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

enum UserZone {
  North
  South
  East
  West
}

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  name                  String?
  email                 String    @unique
  accountingEmail       String?
  authorizationPassword String?
  password              String
  unc                   String?
  keyParse              String?
  isStatus              Int       @default(1)
  zone                  UserZone?
  cutDiscount           String?
  rollDiscount          String?
  role                  String    @default("user")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("users")
}

model Setting {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  smtp_email           String?
  smtp_pass            String?
  image                String?
  receiving_order_days Int?
  ebrochure            String?
  gst                  Int?
  qr_link              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("settings")
}

model CartItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  productId   String
  productName String?
  pattern     String?
  color       String?
  price       Float?
  rollPrice   Float?
  cutPrice    Float?
  gstPercent  Float?
  quantity    Float    @default(1)
  unit        String?
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("cart_items")
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model UserContact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  name       String?
  phone      String?
  email      String?
  department String?
  isDefault  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("user_contacts")
}

model Ad {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  title     String?
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("ads")
}

model Brochure {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String?
  brochure_key String?
  file_name    String?
  qr_code      String?
  qr_code2     String?
  pattern_name String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("brochures")
}

model EbrochureFile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ebrochure String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ebrochure_files")
}

model SearchReport {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  search_string  String?
  pattern        String?
  color          String?
  consignee_name String?
  location       String?
  elpsed_time    String?
  row_count      Int?      @default(0)
  device_type    String?
  os_type        String?
  user_agent     String?
  timestamp      DateTime? @default(now())
  created_at     DateTime? @default(now())
  updated_at     DateTime? @updatedAt

  @@map("search_reports")
}
